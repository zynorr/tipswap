# Public Supabase browser/server URL, not the Postgres connection string.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public app URL used for Telegram Mini App and TON Connect manifest links.
NEXT_PUBLIC_APP_URL=https://your-domain.example

# Optional comma-separated HTTPS hosts for local tunnels during Next.js dev.
NEXT_ALLOWED_DEV_ORIGINS=

# Server-only Supabase service role key. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Telegram bot production token from @BotFather.
TELEGRAM_BOT_TOKEN=replace-with-botfather-token

# Bot username without @. Used for claim links.
TELEGRAM_BOT_USERNAME=tipswapbot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=tipswapbot

# Random webhook secret sent to Telegram and validated by /api/bot.
TELEGRAM_WEBHOOK_SECRET=replace-with-random-32-plus-character-secret

# Random admin token for /admin/setup and /api/bot/setup.
ADMIN_SETUP_TOKEN=replace-with-random-32-plus-character-secret

# Stable encryption key for managed wallet mnemonics. Must never change after users exist.
WALLET_ENCRYPTION_KEY=replace-with-random-32-plus-character-secret

# TONCenter API key. Strongly recommended for production rate limits.
TON_API_KEY=replace-with-toncenter-api-key

# TON Pay is used by the Mini App for external-wallet direct transfers.
# Use mainnet for the current TipSwap production flow.
TONPAY_CHAIN=mainnet
TONPAY_API_KEY=
TONPAY_WEBHOOK_SECRET=
